{
  "name": "production",
  "description": "Strict quality gates, HTML rendering and fail-fast production settings.",
  "env": {
    "TTS_PROVIDER": "nvidia",
    "OPENAI_TTS_CONCURRENCY": "4",
    "TTS_PREPROCESS_CONCURRENCY": "4",
    "TTS_FFMPEG_CONCURRENCY": "2",
    "VIDEO_RENDER_ENGINE": "html-video",
    "HTML_RENDER_CONCURRENCY": "2",
    "HTML_RENDER_PRESET": "medium",
    "QUALITY_GATE_PROFILE": "strict",
    "ASR_MODEL": "openai/whisper-base",
    "ASR_LANGUAGE_CONFIDENCE_MIN": "0.9",
    "ASR_SCENE_TOKEN_COVERAGE_MIN": "0.8",
    "ASR_SCENE_TOKEN_PRECISION_MIN": "0.78",
    "QUALITY_JUDGE_SAMPLES": "2",
    "QUALITY_JUDGE_MAX_SCORE_DELTA": "15",
    "TTS_FAIL_FAST": "1",
    "SCREENSHOT_LIMIT": "1",
    "HARNESS_MAX_ITERATIONS": "3",
    "HARNESS_VIDEO_ITERATIONS": "3",
    "STORY_PLAN_CANDIDATES": "4",
    "TEMPLATE_EXPLORATION_RATE": "0.08"
  },
  "doctor": { "requireApi": true, "requireBrowser": true, "requireWhisper": true }
}
