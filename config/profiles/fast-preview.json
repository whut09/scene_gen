{
  "name": "fast-preview",
  "description": "Fast local preview with fewer loop and video-gate attempts.",
  "env": {
    "TTS_PROVIDER": "openai",
    "VIDEO_RENDER_ENGINE": "remotion",
    "HTML_RENDER_CONCURRENCY": "3",
    "HTML_RENDER_PRESET": "ultrafast",
    "QUALITY_GATE_PROFILE": "lenient",
    "QUALITY_JUDGE_SAMPLES": "1",
    "SCREENSHOT_LIMIT": "0",
    "HARNESS_MAX_ITERATIONS": "1",
    "HARNESS_VIDEO_ITERATIONS": "1",
    "STORY_PLAN_CANDIDATES": "1",
    "TEMPLATE_EXPLORATION_RATE": "0"
  },
  "doctor": { "requireApi": true, "requireBrowser": true }
}
