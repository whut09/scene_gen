{
  "name": "scene-gen",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "bin": {
    "scene-gen": "bin/scene-gen.mjs"
  },
  "scripts": {
    "scene-gen": "tsx src/cli/scene-gen.ts",
    "doctor": "tsx src/cli/scene-gen.ts doctor",
    "plan": "tsx src/cli/scene-gen.ts plan",
    "generate": "tsx src/pipeline/generate.ts",
    "generate:stories": "tsx src/pipeline/generate-stories.ts",
    "render": "tsx src/pipeline/render.ts",
    "render:stories": "tsx src/pipeline/render-stories.ts",
    "render:html-video": "tsx src/pipeline/render-stories.ts --engine html-video",
    "make": "npm run generate:stories && npm run render:stories",
    "preview": "remotion preview src/remotion/index.tsx",
    "lint:types": "tsc --noEmit",
    "generate:protocols": "node scripts/generate-f5-worker-protocol.mjs",
    "test:protocols": "node scripts/generate-f5-worker-protocol.mjs --check",
    "test": "npm run test:unit",
    "test:pronunciation": "python scripts/verify-tts-pronunciation.py --lexicon config/tts/zh-CN.json && tsx --test tests/unit/tts-pronunciation.test.ts",
    "test:worker": "tsx --test tests/unit/f5-worker-client.test.ts",
    "test:incremental": "tsx --test tests/integration/incremental-media-performance.test.ts tests/integration/content-addressed-cache.test.ts tests/integration/scene-audio-regeneration.test.ts tests/integration/html-render-concurrency.test.ts",
    "benchmark:media": "tsx tests/benchmark/media-benchmark.ts",
    "test:unit": "node scripts/run-test-files.mjs src tests/unit",
    "test:offline": "tsx --test tests/integration/*.test.ts",
    "test:golden": "tsx --test tests/golden/*.test.ts",
    "test:ci": "npm run test:protocols && npm run lint:types && npm run test:pronunciation && npm run test:unit && npm run test:worker && npm run test:incremental && npm run test:offline && npm run test:golden && npm audit --audit-level=low",
    "video": "tsx src/cli/scene-gen.ts run",
    "video:check": "tsx src/cli/scene-gen.ts check",
    "video:revise": "tsx src/harness/revise-scenes.ts",
    "feedback:add": "tsx src/cli/scene-gen.ts feedback",
    "synthesize:story": "tsx src/pipeline/synthesize-story.ts",
    "video:remotion": "tsx src/cli/scene-gen.ts run --engine remotion",
    "video:html": "tsx src/cli/scene-gen.ts run --engine html-video",
    "production:inspect": "tsx src/production/inspect-production.ts"
  },
  "dependencies": {
    "@mozilla/readability": "^0.6.0",
    "@remotion/bundler": "4.0.489",
    "@remotion/renderer": "4.0.489",
    "fast-xml-parser": "^5.3.2",
    "jsdom": "^27.2.0",
    "playwright": "^1.60.0",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "remotion": "4.0.489",
    "tsx": "^4.21.0",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@types/jsdom": "^21.1.7",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "typescript": "^5.9.3"
  }
}
