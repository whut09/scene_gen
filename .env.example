F5_TTS_REF_TEXT=
VIDEO_WIDTH=1080
VIDEO_HEIGHT=1920
VIDEO_FPS=30
VIDEO_RENDER_ENGINE=html-video

EXTERNAL_FETCH_TIMEOUT_MS=90000
EXTERNAL_PROCESS_TIMEOUT_MS=300000
HARNESS_DRAFT_TIMEOUT_MS=300000
HARNESS_REVISION_TIMEOUT_MS=180000
HARNESS_SYNTHESIZE_TIMEOUT_MS=900000
